{
  "branches": [
    "main"
  ],
  "tagFormat": "${version}",
  "debug": true,
  "ci": true,
  "dryRun": false,
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "docs/CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "npmPublish": false
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "sed -i \"s|\\\"version\\\": \\\"[^\\\"]*\\\"|\\\"version\\\": \\\"${nextRelease.version}\\\"|\" src/manifest.json && npm run build && (cd dist && zip -r \"../odoo-timeshit-${nextRelease.version}.zip\" odoo-timeshit)"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "docs/CHANGELOG.md",
          "package.json",
          "package-lock.json",
          "src/manifest.json"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "odoo-timeshit-*.zip",
            "name": "odoo-timeshit-${nextRelease.version}.zip",
            "label": "odoo-timeshit ${nextRelease.version} (built Chrome extension)"
          }
        ]
      }
    ]
  ]
}
