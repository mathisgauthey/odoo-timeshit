{
  "manifest_version": 3,
  "name": "Odoo Timesheet Tracker",
  "version": "1.7.1",
  "description": "Track timesheets in Odoo directly from your browser. Includes Azure DevOps timer integration.",
  "permissions": [
    "storage",
    // Cookie login reads the Odoo `session_id` cookie to detect an existing
    // browser session; paired with the `<all_urls>` host permission below.
    "cookies"
    // TODO: Remove these apparently ?
    //    "activeTab",
    //    "webNavigation",
    //    "webRequest",
    //    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  }
}
